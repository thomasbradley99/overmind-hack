# Copy to .env and fill in your key:  cp .env.example .env
GEMINI_API_KEY=your-gemini-api-key-here

# Model used by classify.py (this is one of the knobs Overmind can optimize)
CLASSIFIER_MODEL=gemini-3.5-flash

# --- Legacy full-game pipeline (see legacy/) ---
STAGE2_MODEL=gemini-3.5-flash
STAGE3_MODEL=gemini-3.5-flash
STAGE4_MODEL=gemini-3.5-flash
CHUNK_DURATION=60
CHUNK_OVERLAP=15
