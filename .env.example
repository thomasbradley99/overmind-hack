# Copy to .env and fill in your key:  cp .env.example .env
GEMINI_API_KEY=your-google-ai-studio-key-here

# --- Optional tuning (sensible defaults already baked into the code) ---
# How long each video chunk is, and how much chunks overlap (seconds)
CHUNK_DURATION=60
CHUNK_OVERLAP=15

# Which Gemini model each stage uses
STAGE2_MODEL=gemini-2.5-flash
STAGE3_MODEL=gemini-2.5-flash
STAGE4_MODEL=gemini-2.5-pro
