# Copy to .env and fill in your key:  cp .env.example .env
GEMINI_API_KEY=your-gemini-api-key-here

# Model used by classify.py (this is one of the knobs Overmind can optimize)
CLASSIFIER_MODEL=gemini-3.5-flash
# Local Qwen (swap Gemini for Qwen3-VL via Ollama):
#   ollama pull qwen3-vl:8b
#   CLASSIFIER_BACKEND=qwen
#   CLASSIFIER_MODEL=qwen3-vl:8b
# Other local: CLASSIFIER_BACKEND=ollama  CLASSIFIER_MODEL=llava-llama3
OLLAMA_HOST=http://127.0.0.1:11434
LOCAL_VLM_SCALE=384
LOCAL_VLM_FRAMES=4
# 0 = identical reruns; 0.1–0.3 = sampling variance (use classify.py --temperature --runs)
CLASSIFIER_TEMPERATURE=0

# --- Legacy full-game pipeline (see legacy/) ---
STAGE2_MODEL=gemini-3.5-flash
STAGE3_MODEL=gemini-3.5-flash
STAGE4_MODEL=gemini-3.5-flash
CHUNK_DURATION=60
CHUNK_OVERLAP=15
